{
  "info": {
    "name": "Project Odyssey - Social Feed API",
    "description": "API collection for testing the social feed module (Module C)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Blog Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"blog\",\n  \"content\": {\n    \"type\": \"doc\",\n    \"content\": [\n      {\n        \"type\": \"heading\",\n        \"attrs\": { \"level\": 1 },\n        \"content\": [\n          { \"type\": \"text\", \"text\": \"My Amazing Trip to Cox's Bazar\" }\n        ]\n      },\n      {\n        \"type\": \"paragraph\",\n        \"content\": [\n          { \"type\": \"text\", \"text\": \"Just visited the longest sea beach in the world! The sunset was breathtaking 🌅\" }\n        ]\n      }\n    ]\n  },\n  \"tripId\": \"uuid-from-supabase\",\n  \"tripName\": \"Cox's Bazar Beach Trip\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/posts",
              "host": ["{{base_url}}"],
              "path": ["api", "posts"]
            }
          }
        },
        {
          "name": "Get All Posts (Feed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/posts?limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "posts"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "type",
                  "value": "blog",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/posts/:postId",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", ":postId"],
              "variable": [
                {
                  "key": "postId",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": {\n    \"type\": \"doc\",\n    \"content\": [\n      {\n        \"type\": \"paragraph\",\n        \"content\": [\n          { \"type\": \"text\", \"text\": \"Updated content here...\" }\n        ]\n      }\n    ]\n  },\n  \"tripName\": \"Updated Trip Name\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/posts/:postId",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", ":postId"],
              "variable": [
                {
                  "key": "postId",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/posts/:postId",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", ":postId"],
              "variable": [
