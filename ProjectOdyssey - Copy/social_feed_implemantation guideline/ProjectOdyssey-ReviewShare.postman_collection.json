{
  "info": {
    "name": "Project Odyssey - Review Share Feature",
    "description": "Test collection for the Review Share feed feature (Module C extension).\n\nSetup:\n1. Set `base_url` = http://localhost:4000\n2. Login and paste your JWT into `jwt_token`\n3. Run requests top to bottom",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Login (get JWT token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('jwt_token', res.token);",
                  "    console.log('✅ JWT saved automatically');",
                  "} else {",
                  "    console.log('⚠️ No token in response — check credentials');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your@email.com\",\n  \"password\": \"yourpassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "1. POST /api/posts/review-share (direct fields)",
      "item": [
        {
          "name": "✅ Share review — all fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('success is true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('type is review', () => pm.expect(res.data.type).to.eql('review'));",
                  "pm.test('reviewData.placeName exists', () => pm.expect(res.data.reviewData.placeName).to.be.a('string'));",
                  "pm.test('reviewData.rating is 4', () => pm.expect(res.data.reviewData.rating).to.eql(4));",
                  "if (res.data && res.data._id) {",
                  "    pm.collectionVariables.set('review_post_id', res.data._id);",
                  "    console.log('✅ review_post_id saved:', res.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"placeName\": \"Lalbagh Fort\",\n  \"rating\": 4,\n  \"title\": \"Historic gem in the heart of Dhaka\",\n  \"comment\": \"The Mughal architecture is absolutely stunning. A must visit if you're in Dhaka.\",\n  \"images\": [\n    \"https://upload.wikimedia.org/wikipedia/commons/thumb/8/8e/Lalbagh_fort.jpg/1024px-Lalbagh_fort.jpg\"\n  ],\n  \"placeType\": \"POI\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/posts/review-share",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "review-share"]
            }
          }
        },
        {
          "name": "✅ Share review — minimal (no title/images)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"placeName\": \"Sundarbans National Park\",\n  \"rating\": 5,\n  \"comment\": \"Saw a Royal Bengal Tiger from the boat. Absolutely surreal.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/posts/review-share",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "review-share"]
            }
          }
        },
        {
          "name": "✅ Share review — rating 1 (negative review)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
