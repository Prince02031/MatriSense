              "raw": "{\n  \"placeName\": \"Some Overrated Tourist Trap\",\n  \"rating\": 1,\n  \"title\": \"Disappointing\",\n  \"comment\": \"Way too crowded, overpriced, and not worth the trip.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/posts/review-share",
