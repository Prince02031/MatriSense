{
  "info": {
    "name": "Project Odyssey - Smart Feed & Follow System",
    "description": "Test collection for the smart personalised feed and follow/unfollow system.\n\nTest order:\n1. Login (auto-saves token)\n2. Follow/Unfollow operations\n3. Smart Feed — page 1, 2, 3 (scroll simulation)\n4. All Caught Up — verify message when feed is exhausted",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Login as User A (Alfi)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('jwt_token_a', res.token);",
                  "    pm.collectionVariables.set('user_id_a', res.user?._id || res._id || '');",
                  "    console.log('✅ User A JWT saved');",
                  "} else {",
                  "    console.log('⚠️ No token — check credentials');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alfi@example.com\",\n  \"password\": \"yourpassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login as User B (Ekanto)",
