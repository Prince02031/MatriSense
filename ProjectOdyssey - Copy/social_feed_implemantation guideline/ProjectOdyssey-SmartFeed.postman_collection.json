    {
      "name": "3. Verify Feed Composition",
      "item": [
        {
          "name": "🔍 Verify _feedSource field on posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const sources = res.data.map(p => p._feedSource);",
                  "pm.test('All posts have _feedSource field', () => {",
                  "    sources.forEach(s => pm.expect(s).to.be.oneOf(['friends', 'trending']));",
                  "});",
                  "",
                  "const friendsCount  = sources.filter(s => s === 'friends').length;",
                  "const trendingCount = sources.filter(s => s === 'trending').length;",
                  "console.log(`Friends: ${friendsCount}, Trending: ${trendingCount}`);",
                  "console.log('Pattern:', sources.join(' → '));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_b}}" }],
            "url": {
              "raw": "{{base_url}}/api/posts/feed?limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "feed"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        },
        {
          "name": "🔍 Verify pagination object shape",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const p = res.pagination;",
                  "pm.test('hasMore is boolean', () => pm.expect(p.hasMore).to.be.a('boolean'));",
                  "pm.test('allCaughtUp is boolean', () => pm.expect(p.allCaughtUp).to.be.a('boolean'));",
                  "pm.test('page stats exist', () => {",
                  "    pm.expect(p.page).to.have.property('friendsOnThisPage');",
                  "    pm.expect(p.page).to.have.property('trendingOnThisPage');",
                  "    pm.expect(p.page).to.have.property('total');",
                  "});",
                  "if (p.hasMore) {",
                  "    pm.test('nextCursor exists when hasMore=true', () => pm.expect(p.nextCursor).to.be.a('string'));",
                  "} else {",
                  "    pm.test('message exists when allCaughtUp=true', () => pm.expect(p.message).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_b}}" }],
            "url": {
              "raw": "{{base_url}}/api/posts/feed?limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "feed"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        }
      ]
    }
