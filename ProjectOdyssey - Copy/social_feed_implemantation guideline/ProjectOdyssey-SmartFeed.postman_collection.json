    {
      "name": "2. Smart Feed — Infinite Scroll Simulation",
      "item": [
        {
          "name": "📄 Page 1 — No cursor (first load)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('success true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('data is array', () => pm.expect(res.data).to.be.an('array'));",
                  "",
                  "const p = res.pagination;",
                  "console.log('--- PAGE 1 ---');",
                  "console.log('Posts returned:', res.data.length);",
                  "console.log('Friends posts:', p.page.friendsOnThisPage);",
                  "console.log('Trending posts:', p.page.trendingOnThisPage);",
                  "console.log('Has more:', p.hasMore);",
                  "console.log('All caught up:', p.allCaughtUp);",
                  "console.log('Post types:', res.data.map(p => `${p._feedSource}:${p.type}`));",
                  "",
                  "if (p.nextCursor) {",
                  "    pm.collectionVariables.set('feed_cursor_1', p.nextCursor);",
                  "    console.log('✅ cursor_1 saved');",
                  "}",
                  "if (p.allCaughtUp) {",
                  "    console.log('🎉', p.message);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_b}}" }],
            "url": {
              "raw": "{{base_url}}/api/posts/feed?limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "feed"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        },
