{
  "info": {
    "name": "Project Odyssey - User Search & Public Profiles",
    "description": "Test collection for user search and public profile endpoints.\n\nTest order:\n1. Login (saves token + userId)\n2. Search — various queries\n3. Public profile — own, other user, private user, unauthenticated\n4. Edge cases",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Login as Ekanto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('jwt_token_ekanto', res.token);",
                  "    pm.collectionVariables.set('user_id_ekanto', res.user?.id || res.user?._id || '');",
                  "    console.log('✅ Ekanto JWT saved');",
                  "} else {",
                  "    console.log('⚠️  No token — check credentials');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ekanto\",\n  \"password\": \"yourpassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login as Alfi",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('jwt_token_alfi', res.token);",
                  "    pm.collectionVariables.set('user_id_alfi', res.user?.id || res.user?._id || '');",
                  "    console.log('✅ Alfi JWT saved, ID:', pm.collectionVariables.get('user_id_alfi'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alfi\",\n  \"password\": \"yourpassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Search Users",
      "item": [
        {
          "name": "✅ Search by username (authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('success true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('data is array', () => pm.expect(res.data).to.be.an('array'));",
                  "pm.test('count matches data length', () => pm.expect(res.count).to.equal(res.data.length));",
                  "",
                  "// Check each result has required fields",
                  "res.data.forEach((u, i) => {",
                  "    pm.test(`result[${i}] has _id`, () => pm.expect(u._id).to.be.a('string'));",
                  "    pm.test(`result[${i}] has username`, () => pm.expect(u.username).to.be.a('string'));",
                  "    pm.test(`result[${i}] has isPrivate flag`, () => pm.expect(u.isPrivate).to.be.a('boolean'));",
                  "    if (!u.isPrivate) {",
                  "        pm.test(`result[${i}] public — has isFollowing`, () => pm.expect(u.isFollowing).to.be.a('boolean'));",
                  "    }",
                  "});",
                  "",
                  "console.log('Results:', res.data.map(u => `${u.username} (private=${u.isPrivate}, following=${u.isFollowing})`));",
                  "",
                  "// Save first result ID for profile tests",
                  "if (res.data.length > 0) {",
                  "    pm.collectionVariables.set('search_result_user_id', res.data[0]._id);",
                  "    console.log('Saved first result ID:', res.data[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/search?q=alfi",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "search"],
              "query": [{ "key": "q", "value": "alfi" }]
            }
          }
        },
        {
          "name": "✅ Search — unauthenticated (no token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 even without token', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('returns results', () => pm.expect(res.data).to.be.an('array'));",
                  "",
                  "// isFollowing should always be false when not authenticated",
                  "res.data.filter(u => !u.isPrivate).forEach((u, i) => {",
                  "    pm.test(`result[${i}] isFollowing=false (no auth)`, () => pm.expect(u.isFollowing).to.be.false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/search?q=alfi",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "search"],
              "query": [{ "key": "q", "value": "alfi" }]
            }
          }
        },
        {
          "name": "✅ Search with custom limit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('max 3 results returned', () => pm.expect(res.data.length).to.be.at.most(3));",
                  "console.log('Count with limit=3:', res.count);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/search?q=a&limit=3",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "search"],
              "query": [
                { "key": "q", "value": "a" },
                { "key": "limit", "value": "3" }
              ]
            }
          }
        },
        {
          "name": "✅ Search — no results",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('count is 0', () => pm.expect(res.count).to.equal(0));",
                  "pm.test('data is empty array', () => pm.expect(res.data).to.deep.equal([]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/search?q=xyzzy_nobody_has_this_username_12345",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "search"],
              "query": [{ "key": "q", "value": "xyzzy_nobody_has_this_username_12345" }]
            }
          }
        },
        {
          "name": "❌ Search — missing q param",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "const res = pm.response.json();",
                  "pm.test('error mentions q param', () => pm.expect(res.error.toLowerCase()).to.include('q'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/search",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "search"]
            }
          }
        },
        {
          "name": "❌ Search — empty q string",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/search?q=",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "search"],
              "query": [{ "key": "q", "value": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "2. Public Profile",
      "item": [
        {
          "name": "✅ View another user's profile (authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "const d = res.data;",
                  "pm.test('success true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('has _id', () => pm.expect(d._id).to.be.a('string'));",
                  "pm.test('isOwnProfile is false', () => pm.expect(d.isOwnProfile).to.be.false);",
                  "pm.test('isFollowing is boolean', () => pm.expect(d.isFollowing).to.be.a('boolean'));",
                  "",
                  "if (!d.isPrivate) {",
                  "    pm.test('has stats', () => {",
                  "        pm.expect(d.stats).to.have.property('followersCount');",
                  "        pm.expect(d.stats).to.have.property('followingCount');",
                  "        pm.expect(d.stats).to.have.property('postsCount');",
                  "    });",
                  "    pm.test('recentPosts is array', () => pm.expect(d.recentPosts).to.be.an('array'));",
                  "    pm.test('max 6 recent posts', () => pm.expect(d.recentPosts.length).to.be.at.most(6));",
                  "}",
                  "",
                  "console.log('Profile:', d.username, '| followers:', d.stats?.followersCount, '| posts:', d.stats?.postsCount);",
                  "console.log('isFollowing:', d.isFollowing, '| isPrivate:', d.isPrivate);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id_alfi}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id_alfi}}"]
            }
          }
        },
        {
          "name": "✅ View own profile (isOwnProfile = true)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "const d = res.data;",
                  "pm.test('isOwnProfile is TRUE', () => pm.expect(d.isOwnProfile).to.be.true);",
                  "pm.test('isFollowing is false for self', () => pm.expect(d.isFollowing).to.be.false);",
                  "pm.test('has stats', () => pm.expect(d.stats).to.exist);",
                  "pm.test('recentPosts present (even if showTripHistory off)', () => pm.expect(d.recentPosts).to.be.an('array'));",
                  "console.log('Own profile stats:', d.stats);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_alfi}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id_alfi}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id_alfi}}"]
            }
          }
        },
        {
          "name": "✅ View profile — unauthenticated (no token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "const d = res.data;",
                  "pm.test('isFollowing false without auth', () => pm.expect(d.isFollowing).to.be.false);",
                  "pm.test('isOwnProfile false without auth', () => pm.expect(d.isOwnProfile).to.be.false);",
                  "console.log('Unauthenticated view:', d.username);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id_alfi}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id_alfi}}"]
            }
          }
        },
        {
          "name": "✅ View profile — check isFollowing TRUE (follow first)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Ensure Ekanto follows Alfi before this test",
                  "// (run the follow request first if needed)"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.test('isFollowing is TRUE', () => pm.expect(d.isFollowing).to.be.true);",
                  "console.log('isFollowing after following:', d.isFollowing);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id_alfi}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id_alfi}}"]
            }
          }
        },
        {
          "name": "✅ View private profile (stub only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "// If this user is actually private:",
                  "if (d.isPrivate) {",
                  "    pm.test('private profile has no stats', () => pm.expect(d.stats).to.be.undefined);",
                  "    pm.test('private profile has no recentPosts', () => pm.expect(d.recentPosts).to.be.undefined);",
                  "    pm.test('has _id, username, displayName, profileImage', () => {",
                  "        pm.expect(d._id).to.exist;",
                  "        pm.expect(d.username).to.exist;",
                  "        pm.expect(d.displayName).to.exist;",
                  "        pm.expect(d.profileImage).to.exist;",
                  "    });",
                  "    console.log('✅ Private profile — stub only:', d.username);",
                  "} else {",
                  "    console.log('⚠️  Replace {{private_user_id}} with an actual private profile user ID');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/{{private_user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{private_user_id}}"]
            }
          }
        },
        {
          "name": "❌ Profile — user not found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "const res = pm.response.json();",
                  "pm.test('error says not found', () => pm.expect(res.error.toLowerCase()).to.include('not found'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/000000000000000000000000",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "000000000000000000000000"]
            }
          }
        },
        {
          "name": "❌ Profile — invalid ObjectId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 500 or 404', () => pm.expect(pm.response.code).to.be.oneOf([404, 500]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/not-a-valid-id",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "not-a-valid-id"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Search → Profile → Follow Flow",
      "item": [
        {
          "name": "Step 1 — Search for 'alfi'",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const alfi = res.data.find(u => u.username === 'alfi');",
                  "if (alfi) {",
                  "    pm.collectionVariables.set('user_id_alfi', alfi._id);",
                  "    console.log('Found alfi, ID:', alfi._id, '| isFollowing:', alfi.isFollowing);",
                  "} else {",
                  "    console.log('alfi not found in results — check username');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/search?q=alfi",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "search"],
              "query": [{ "key": "q", "value": "alfi" }]
            }
          }
        },
        {
          "name": "Step 2 — Load Alfi's full profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "console.log('Profile loaded — followers:', d.stats?.followersCount);",
                  "console.log('isFollowing before follow:', d.isFollowing);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id_alfi}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id_alfi}}"]
            }
          }
        },
        {
          "name": "Step 3 — Follow Alfi",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "console.log('Followed! Now reload profile to verify isFollowing=true');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/follow/{{user_id_alfi}}",
              "host": ["{{base_url}}"],
              "path": ["api", "follow", "{{user_id_alfi}}"]
            }
          }
        },
        {
          "name": "Step 4 — Reload profile (isFollowing should be true now)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.test('isFollowing is now TRUE', () => pm.expect(d.isFollowing).to.be.true);",
                  "console.log('✅ isFollowing:', d.isFollowing, '| followers:', d.stats?.followersCount);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token_ekanto}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id_alfi}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id_alfi}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url",         "value": "http://localhost:4000" },
    { "key": "jwt_token_ekanto", "value": "" },
    { "key": "jwt_token_alfi",   "value": "" },
    { "key": "user_id_ekanto",   "value": "" },
    { "key": "user_id_alfi",     "value": "" },
    { "key": "private_user_id",  "value": "REPLACE_WITH_A_PRIVATE_PROFILE_USER_ID" },
    { "key": "search_result_user_id", "value": "" }
  ]
}
