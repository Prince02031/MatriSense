{
  "engine": "json-rules-engine",
  "rules": [
    {
      "name": "WHO_WARNING_FEVER_MEDIUM",
      "priority": 60,
      "conditions": {
        "all": [
          { "fact": "symptoms", "operator": "contains", "value": "fever" },
          { "fact": "symptoms", "operator": "notContains", "value": "severe_weakness" }
        ]
      },
      "event": {
        "type": "MEDIUM_RISK",
        "params": {
          "riskLevel": "MEDIUM",
          "recommendedAction": "CONTACT_HEALTH_WORKER_SOON",
          "reason": "Fever during pregnancy should be reviewed by a health worker when severe weakness is not present.",
          "displayReasonBn": "জ্বর থাকলে স্বাস্থ্যকর্মীর পরামর্শ নেওয়া উচিত।",
          "evidenceTag": "WHO_PREGNANCY_DANGER_SIGNS",
          "sourceRef": "WHO Counselling for Maternal and Newborn Health Care (Danger Signs)"
        }
      }
    },
