PORT=5000
CLIENT_URL=http://localhost:3000
MONGODB_URI=
JWT_SECRET=

# LLM Config
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.1
LLM_PROVIDER=gemini

# STT Config (Speech-to-Text)
STT_PROVIDER=groq
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo

# RAG mode (keep json by default until vector smoke tests pass)
RAG_MODE=json

# Local embeddings (default for Vector RAG)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/multilingual-e5-small
EMBEDDING_DIMENSIONS=384

# Note:
# - MongoDB vector index for this model must use 384 dimensions.
# - If switching to Gemini embeddings later, re-ingest and rebuild vector index
#   with Gemini dimensions (commonly 768 for text-embedding-004).
